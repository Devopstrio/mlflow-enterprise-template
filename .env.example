# API Settings
API_V1_STR=/api/v1
PROJECT_NAME="MLflow Enterprise Template"

# Security
SECRET_KEY=mlopsenterpriseplatformsecret123
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# MLflow Settings
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_STORE=s3://mlflow-artifacts
MLFLOW_BACKEND_STORE=postgresql://postgres:postgres@localhost/mlflow

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mlflow_enterprise

# Redis / Queue
REDIS_HOST=localhost
REDIS_PORT=6379

# Model Serving
MODEL_SERVER_URL=http://localhost:8001
SERVING_TIMEOUT=30

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
